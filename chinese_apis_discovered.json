{
  "platform": "mararun.com",
  "description": "Plateforme officielle du Beijing Marathon (et potentiellement autres marathons chinois)",
  "base_url": "https://saas-user-gw.mararun.com/v1",
  "discovered": "2026-03-22",
  "endpoints": {
    "committee/lists": {
      "method": "GET",
      "params": {
        "hostKey": "beijing-host"
      },
      "auth": "Aucune",
      "returns": "Info organisateur (logo, site web, config)"
    },
    "match/lists": {
      "method": "GET",
      "params": {
        "hostKey": "beijing-host"
      },
      "auth": "Aucune",
      "returns": "Liste des editions (2016-2025)",
      "fields": "id, mkey, name, englishName, beginTime, realCnt, totalLimit"
    },
    "captcha/code": {
      "method": "GET",
      "params": {
        "sessionID": "auto-generated"
      },
      "auth": "Aucune",
      "returns": "Image captcha pour validation"
    },
    "score/search": {
      "method": "GET",
      "params": {
        "matchID": "ex: 7944262578758424",
        "IDCard": "numero dossard",
        "sessionID": "session",
        "captcha": "code captcha"
      },
      "auth": "Captcha requis",
      "returns": "Resultat individuel du coureur",
      "limitation": "Recherche individuelle seulement, pas de pagination/listing de masse"
    }
  },
  "editions_beijing_marathon": {
